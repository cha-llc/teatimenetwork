# ============================================================================
# TEA TIME NETWORK - ENVIRONMENT VARIABLES TEMPLATE
# ============================================================================
#
# COPY THIS FILE TO .env.local (development)
# DO NOT commit .env.local to git!
#
# For Vercel production deployment, add these as environment variables
# in the Vercel Dashboard: Project Settings → Environment Variables
#
# ============================================================================

# SUPABASE DATABASE CONFIGURATION (REQUIRED)
# Get these from: https://supabase.com/dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-name.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# STRIPE CONFIGURATION (Optional for local dev, required for production)
# Get test keys from: https://dashboard.stripe.com/test/apikeys
# Get live keys from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_... (or pk_live_...)
STRIPE_SECRET_KEY=sk_test_... (or sk_live_...) [SERVER ONLY]
STRIPE_WEBHOOK_SECRET=whsec_... [SERVER ONLY]

# MCP INTEGRATIONS (Optional)
# Add only the services you want to use

# Socialblu (Social media posting)
SOCIALBLU_API_KEY=your_api_key

# HubSpot (CRM)
HUBSPOT_API_KEY=your_api_key

# Slack (Notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Amplitude (Analytics)
AMPLITUDE_API_KEY=your_api_key

# Gmail (Email sending)
GMAIL_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GMAIL_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...

# Google Calendar (Reminders)
GOOGLE_CALENDAR_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=your_client_secret
GOOGLE_CALENDAR_REFRESH_TOKEN=your_refresh_token

# Linear (Task management)
LINEAR_API_KEY=your_api_key

# Ticket Tailor (Course management)
TICKET_TAILOR_API_KEY=your_api_key

# Jotform (Forms)
JOTFORM_API_KEY=your_api_key

# APP CONFIGURATION
# Development: http://localhost:5173
# Production: https://teatimenetwork.app
VITE_APP_URL=http://localhost:5173
NODE_ENV=development

# VERCEL ANALYTICS (Optional)
VERCEL_ANALYTICS_ID=your_analytics_id
