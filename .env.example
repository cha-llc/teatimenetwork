# Tea Time Network - Environment Variables
# Copy this to .env.local and fill in your actual values
# NEVER commit .env.local to git

# ============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# ============================================================================

# Supabase Project URL - Get from https://app.supabase.com/project/[project-id]/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key - Get from https://app.supabase.com/project/[project-id]/settings/api
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (server-side only - never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# STRIPE CONFIGURATION (REQUIRED)
# ============================================================================

# Stripe Publishable Key - Get from https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Stripe Secret Key - Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Stripe Webhook Secret - Get after creating webhook endpoint
STRIPE_WEBHOOK_SECRET=whsec_test_your-webhook-secret

# ============================================================================
# AUTHENTICATION & ADMIN
# ============================================================================

# CJ's Supabase User ID (Admin - full access)
# Get this from Supabase Auth users list after CJ signs up
REACT_APP_CJ_UID=user-uuid-here

# Admin notification email
ADMIN_EMAIL=cj@teatimenetwork.com

# Support contact email
SUPPORT_EMAIL=support@teatimenetwork.com

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment (development, staging, production)
VITE_ENV=development

# App name for branding
VITE_APP_NAME=Tea Time Network

# API base URL
VITE_API_URL=http://localhost:3000

# Enable debug logging (true/false)
VITE_DEBUG=false

# ============================================================================
# OPTIONAL: ANALYTICS
# ============================================================================

# Google Analytics Tracking ID (optional)
VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Amplitude API Key (optional)
VITE_AMPLITUDE_KEY=

# ============================================================================
# CORS & SECURITY
# ============================================================================

# Allowed CORS origins (comma-separated)
VITE_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Session timeout in minutes (optional - defaults to 24 hours)
SESSION_TIMEOUT_MINUTES=1440

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================

# 1. Get Supabase credentials:
#    - Go to https://app.supabase.com
#    - Create or select your project
#    - Settings → API
#    - Copy URL and Anon Key
#
# 2. Get Stripe credentials:
#    - Go to https://dashboard.stripe.com
#    - Developers → API Keys
#    - Copy Publishable and Secret keys
#
# 3. Get CJ's UID:
#    - In Supabase: Authentication → Users
#    - Sign up with CJ's email
#    - Copy the UUID
#
# 4. Create webhook:
#    - Stripe → Developers → Webhooks
#    - Create webhook for events: customer.subscription.*, payment_intent.*
#    - Copy webhook secret
#
# 5. Copy this file to .env.local and fill in all values
#
# 6. Run: npm run dev

# ============================================================================
# SECURITY NOTES
# ============================================================================

# VITE_ prefix: Client-side only (safe to expose)
# No prefix: Server-side only (NEVER expose to frontend)
#
# Safe to expose:
# - VITE_SUPABASE_URL
# - VITE_SUPABASE_ANON_KEY
# - VITE_STRIPE_PUBLISHABLE_KEY
#
# NEVER expose to client:
# - SUPABASE_SERVICE_ROLE_KEY
# - STRIPE_SECRET_KEY
# - STRIPE_WEBHOOK_SECRET
#
# If keys are compromised:
# 1. Regenerate them in their respective dashboards
# 2. Update .env.local
# 3. Restart development server
# 4. If in production, deploy new environment variables

