{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "allowJs": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "strictNullChecks": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-native"
  },
  "include": [
    "index.js",
    "src/App.tsx",
    "src/contexts/AuthContext.tsx",
    "src/lib/supabase.ts",
    "src/lib/theme.ts",
    "src/navigation/**/*.ts",
    "src/navigation/**/*.tsx",
    "src/screens/**/*.ts",
    "src/screens/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "babel.config.js",
    "src/components",
    "src/pages",
    "src/hooks",
    "src/services",
    "src/integrations",
    "src/stores",
    "src/test",
    "src/contexts/AppContext.tsx",
    "src/contexts/LanguageContext.tsx",
    "src/main.tsx",
    "src/api"
  ]
}
